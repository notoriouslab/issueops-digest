# === Required ===
BRAVE_API_KEY=           # https://brave.com/search/api/ (requires credit card, $5 free credit ~1000 calls/mo)
GEMINI_API_KEY=          # https://aistudio.google.com/apikey (free tier: 1500 req/day)
GITHUB_TOKEN=            # https://github.com/settings/tokens (repo scope)
GITHUB_REPO=             # your-username/issueops-digest (the repo where Issues will be created)

# === Optional (enhances search quality) ===
TAVILY_API_KEY=          # https://tavily.com/ (free: 1000 calls/mo)

# === Optional (push notifications) ===
TELEGRAM_BOT_TOKEN=      # Talk to @BotFather on Telegram to create a bot
TELEGRAM_CHAT_ID=        # Send /start to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
